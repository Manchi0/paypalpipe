# ── PayPal Credentials ───────────────────────────────────────────────────────
# From: https://developer.paypal.com → My Apps & Credentials → your app
PAYPAL_CLIENT_ID=YOUR_CLIENT_ID_HERE
PAYPAL_CLIENT_SECRET=YOUR_CLIENT_SECRET_HERE

# "sandbox" for testing, "live" for real transactions
PAYPAL_MODE=sandbox

# Only fetch transactions on or after this date (YYYY-MM-DD)
PAYPAL_START_DATE=2026-01-15

# ── Google Admin SDK (optional) ───────────────────────────────────────────────
# Skip this section if you don't need the Google Group feature.
# Path to your downloaded service account JSON key file
GOOGLE_SERVICE_ACCOUNT_FILE=service_account.json

# A super-admin email in your Google Workspace domain to impersonate
GOOGLE_ADMIN_EMAIL=admin@yourdomain.com

# The Google Group email address to add payers to
GOOGLE_GROUP_EMAIL=members@yourdomain.com

# ── Output ───────────────────────────────────────────────────────────────────
EXCEL_OUTPUT_PATH=transactions.xlsx
