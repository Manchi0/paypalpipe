# ── PayPal Credentials ───────────────────────────────────────────────────────
# From: https://developer.paypal.com → My Apps & Credentials → Sandbox app
PAYPAL_CLIENT_ID=YOUR_SANDBOX_CLIENT_ID
PAYPAL_CLIENT_SECRET=YOUR_SANDBOX_CLIENT_SECRET

# Set to "sandbox" for testing, "live" for production
PAYPAL_MODE=sandbox

# How many days back to fetch transactions (max 31 per API call)
PAYPAL_DAYS_BACK=30

# ── Google Admin SDK ─────────────────────────────────────────────────────────
# Path to your downloaded service account JSON key file
GOOGLE_SERVICE_ACCOUNT_FILE=service_account.json

# A super-admin email in your Google Workspace domain to impersonate
GOOGLE_ADMIN_EMAIL=admin@yourdomain.com

# The Google Group email address to add members to
GOOGLE_GROUP_EMAIL=members@yourdomain.com

# ── Output ───────────────────────────────────────────────────────────────────
EXCEL_OUTPUT_PATH=transactions.xlsx
